#!/bin/sh
set -eu

if ! command -v c3fmt >/dev/null 2>&1; then
	echo "warning: c3fmt is not installed; skipping pre-commit formatting." >&2
	echo "Install it when you can. See CONTRIBUTING.md." >&2
	exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

files=$(mktemp)
formatted=$(mktemp)
trap 'rm -f "$files" "$formatted"' EXIT

git ls-files '*.c3' '*.c3i' > "$files"
if [ ! -s "$files" ]; then
	exit 0
fi

echo "Running c3fmt on tracked C3 files..."
failed=0
while IFS= read -r file; do
	if c3fmt --in-place "$file"; then
		printf '%s\n' "$file" >> "$formatted"
	else
		echo "warning: c3fmt failed while formatting $file; leaving it unchanged." >&2
		failed=1
	fi
done < "$files"

# Include formatter edits in the commit. The file list comes from git ls-files,
# so this does not add untracked files or recurse into submodule contents.
if [ -s "$formatted" ]; then
	xargs git add -- < "$formatted"
fi

if [ "$failed" -ne 0 ]; then
	echo "warning: c3fmt had failures; continuing so the commit is not blocked." >&2
fi
