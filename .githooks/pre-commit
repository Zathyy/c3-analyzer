#!/bin/sh
set -eu

if ! command -v c3fmt >/dev/null 2>&1; then
	echo "warning: c3fmt is not installed; skipping pre-commit formatting." >&2
	echo "Install it when you can. See CONTRIBUTING.md." >&2
	exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

files=$(mktemp)
tmpdir=$(mktemp -d)
trap 'rm -f "$files"; rm -rf "$tmpdir"' EXIT

git diff --cached --name-only --diff-filter=AM -- '*.c3' '*.c3i' '*.c3l' > "$files"
if [ ! -s "$files" ]; then
	exit 0
fi

echo "Running c3fmt on staged C3 files..."
failed=0
while IFS= read -r file; do
	input="$tmpdir/input"
	output="$tmpdir/formatted"
	if git show ":$file" > "$input" && c3fmt --stdin --stdout < "$input" > "$output"; then
		mode=$(git ls-files -s -- "$file" | awk 'NR == 1 { print $1 }')
		blob=$(git hash-object -w "$output")
		git update-index --cacheinfo "$mode" "$blob" "$file"
	else
		echo "warning: c3fmt failed while formatting $file; leaving it unchanged." >&2
		failed=1
	fi
	rm -f "$input" "$output"
done < "$files"

if [ "$failed" -ne 0 ]; then
	echo "warning: c3fmt had failures; continuing so the commit is not blocked." >&2
fi
